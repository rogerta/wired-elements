{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "lib": [
      "es2023",
      "dom"
    ],
    "types": ["vite/client"],
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "declaration": true,
    "removeComments": true,
    "rootDir": "./src",
    "outDir": "./lib",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
  },
  "include": ["src"]
}